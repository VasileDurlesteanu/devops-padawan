# Local .terraform directories (contains plugins and binaries)
**/.terraform/*
**/.terraform.lock**

# .tfstate files (contains sensitive infrastructure state data)
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc